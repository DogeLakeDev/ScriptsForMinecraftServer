{
  "name": "sfmc-cil",
  "version": "0.1.0",
  "private": true,
  "description": "REPL management tool for ScriptsForMinecraftServer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "bin": {
    "sfmc": "./dist/main.js"
  },
  "scripts": {
    "start": "node ./dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/main.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "jsonc-parser": "^3.3.1",
    "jszip": "^3.10.1",
    "ws": "^8.21.1"
  }
}
