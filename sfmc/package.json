{
  "name": "@sfmc-bds/cli",
  "version": "0.1.0",
  "description": "SFMC management CLI — REPL, service supervisor, module install, behavior-pack build/deploy",
  "type": "module",
  "license": "ISC",
  "author": "Shiroha7z",
  "homepage": "https://github.com/DogeLakeDev/ScriptsForMinecraftServer/tree/main/sfmc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DogeLakeDev/ScriptsForMinecraftServer.git",
    "directory": "sfmc"
  },
  "bugs": {
    "url": "https://github.com/DogeLakeDev/ScriptsForMinecraftServer/issues"
  },
  "keywords": [
    "minecraft-bedrock",
    "sfmc",
    "cli",
    "scriptsforminecraftserver"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    }
  },
  "bin": {
    "sfmc": "./dist/main.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "node ./dist/main.js",
    "build": "node ../scripts/esbuild-transpile.mjs --dts",
    "typecheck": "tsc7 --noEmit -p tsconfig.json",
    "test": "node --test pack-update-policy.test.mjs terminal-progress.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sfmc-bds/bds-tools": "^0.1.0",
    "@sfmc-bds/sdk": "^0.1.0",
    "@clack/prompts": "^1.7.0",
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "jsonc-parser": "^3.3.1",
    "ws": "^8.21.1"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
