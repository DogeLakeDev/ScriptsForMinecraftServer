{
  "name": "@sfmc-bds/bds-tools",
  "version": "0.1.0",
  "description": "SFMC BDS auto-updater, lifecycle manager, and behavior-pack assembler",
  "author": "Shiroha7z",
  "type": "module",
  "license": "ISC",
  "homepage": "https://github.com/DogeLakeDev/ScriptsForMinecraftServer/tree/main/bds-tools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DogeLakeDev/ScriptsForMinecraftServer.git",
    "directory": "bds-tools"
  },
  "bugs": {
    "url": "https://github.com/DogeLakeDev/ScriptsForMinecraftServer/issues"
  },
  "keywords": [
    "minecraft-bedrock",
    "sfmc",
    "bds",
    "updater",
    "scriptsforminecraftserver"
  ],
  "main": "dist/bds-manager.js",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./dist/bds-manager.js",
    "./check-update": "./dist/check-update.js",
    "./bds-manager": "./dist/bds-manager.js",
    "./pack-manager": "./dist/cli-pack-manager.js",
    "./package.json": "./package.json",
    "./types": {
      "types": "./dist/types.d.ts"
    }
  },
  "scripts": {
    "build": "node ../scripts/esbuild-transpile.mjs --dts",
    "dev": "tsx src/bds-manager.ts",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "node --test is-main.test.mjs pack-manager-lifecycle.test.mjs",
    "update": "node dist/check-update.js",
    "update:check": "node dist/check-update.js --check-only",
    "update:force": "node dist/check-update.js --force",
    "rollback": "node recovery.js",
    "start": "node dist/bds-manager.js start",
    "stop": "node dist/bds-manager.js stop",
    "status": "node dist/bds-manager.js status",
    "watch": "node dist/bds-manager.js watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sfmc-bds/sdk": "^0.1.0",
    "cli-progress": "^3.12.0",
    "jszip": "^3.10.1",
    "node-html-parser": "^9.0.0"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
