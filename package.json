{
  "name": "sfmc-monorepo",
  "private": true,
  "devDependencies": {
    "@minecraft/server": "2.10.0-beta.1.26.40-preview.30",
    "@minecraft/server-net": "^1.0.0-beta.1.26.33-stable",
    "@minecraft/server-ui": "2.2.0-beta.1.26.40-preview.30",
    "@minecraft/vanilla-data": "1.26.40-preview.30",
    "@types/cli-progress": "^3.11.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "nodemon": "^3.1.14",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "properties-reader": "^3.0.1",
    "rimraf": "^6.1.3",
    "source-map": "^0.7.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "lodash": "^4.18.1",
    "jszip": "^3.10.1"
  },
  "scripts": {
    "start": "node sfmc/dist/main.js",
    "build": "npm run build --workspaces --if-present",
    "sdk:build": "npm run build --workspace @sfmc/sdk",
    "sdk:typecheck": "npm run typecheck --workspace @sfmc/sdk",
    "sdk:verify": "npm run sdk:typecheck && npm run sdk:build",
    "module-core:build": "npm run sdk:build",
    "module-core:typecheck": "npm run sdk:typecheck",
    "module-core:test": "echo \"no sdk tests yet\"",
    "module-core:verify": "npm run sdk:verify",
    "check-modules": "node tools/check-modules.mjs",
    "catalog-sync": "node tools/catalog-sync.mjs",
    "check-ootb": "node tools/check-ootb.mjs",
    "smoke-modules": "node tools/smoke-modules.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "bundle": "node build-sea.mjs",
    "sea": "node --build-sea sea-config.json"
  },
  "workspaces": [
    "modules/sdk/@sfmc-sdk",
    "modules/packages/*",
    "db-server",
    "qq-bridge",
    "bds-tools",
    "sfmc",
    "remote-controller"
  ],
  "allowScripts": {
    "esbuild@0.28.1": true
  },
  "type": "module"
}
