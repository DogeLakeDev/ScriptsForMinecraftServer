{
  "name": "scriptsforminecraftserver-monorepo",
  "bin": {
    "sfmc": "index.js"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "nodemon": "^3.1.14",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "source-map": "^0.7.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "start": "node index.js",
    "build": "npm run build --workspaces",
    "sdk:build": "npm run build --workspace @sfmc/sdk",
    "sdk:typecheck": "npm run typecheck --workspace @sfmc/sdk",
    "sdk:verify": "npm run sdk:typecheck && npm run sdk:build",
    "module-core:build": "npm run sdk:build",
    "module-core:typecheck": "npm run sdk:typecheck",
    "module-core:test": "echo \"no sdk tests yet\"",
    "module-core:verify": "npm run sdk:verify",
    "check-catalog": "node /tools/check-catalog.js",
    "lint": "eslint . --ext .ts,.tsx",
    "bundle": "node build-sea.mjs",
    "sea": "node --build-sea sea-config.json"
  },
  "workspaces": [
    "modules/sdk/@sfmc-sdk",
    "modules/packages/*",
    "db-server",
    "scriptsforminecraftserver",
    "qq-bridge",
    "bds-tools",
    "sfmc",
    "remote-controller"
  ],
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
