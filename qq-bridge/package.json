{
  "name": "@sfmc-bds/qq-bridge",
  "version": "0.1.0",
  "description": "SFMC QQ ↔ MC bridge — LLBot OneBot 11 reverse-WS on port 3002, forwards events to db-server",
  "author": "Shiroha7z",
  "type": "module",
  "license": "ISC",
  "homepage": "https://github.com/DogeLakeDev/ScriptsForMinecraftServer/tree/main/qq-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DogeLakeDev/ScriptsForMinecraftServer.git",
    "directory": "qq-bridge"
  },
  "bugs": {
    "url": "https://github.com/DogeLakeDev/ScriptsForMinecraftServer/issues"
  },
  "keywords": [
    "minecraft-bedrock",
    "sfmc",
    "qq",
    "onebot",
    "llbot",
    "scriptsforminecraftserver"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "build": "node ../scripts/esbuild-transpile.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json}\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sfmc-bds/sdk": "^0.1.0",
    "ws": "^8.21.1"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
