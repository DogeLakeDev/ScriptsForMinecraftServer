{
  "schemaVersion": 2,
  "id": "feature-chat",
  "name": "聊天系统",
  "type": "feature",
  "configKey": "chat",
  "requires": ["feature-economy"],

  "permissions": [
    "db:read:sfmc_chat_channels",
    "db:write:sfmc_chat_channels",
    "db:read:sfmc_chat_messages",
    "db:write:sfmc_chat_messages",
    "db:read:sfmc_chat_redpackets",
    "db:write:sfmc_chat_redpackets",
    "db:read:sfmc_players",
    "db:write:sfmc_players",
    "config:read:chat",
    "service:economy.account.credit",
    "service:economy.account.debit"
  ],

  "services": {
    "provides": [],
    "requires": [
      { "name": "economy.account.credit", "input": { "type": "object" }, "output": { "type": "object" } },
      { "name": "economy.account.debit", "input": { "type": "object" }, "output": { "type": "object" } }
    ]
  },

  "notes": "v2 聊天系统,合并 v1 chat + chat-gui。频道/消息/红包走 db.tx 写平台 bootstrap 表 sfmc_chat_*;红包扣款/入账走 tx.call(economy.account.*)。QQ 桥接仍使用 db-server v1 routes/messages(平台侧转发),与本模块共享同一张表。ChatGUI MenuNavigator 已接回命令面。"
}
