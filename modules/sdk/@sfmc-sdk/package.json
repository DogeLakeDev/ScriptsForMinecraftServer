{
  "name": "@sfmc-bds/sdk",
  "version": "0.1.0",
  "description": "ScriptsForMinecraftServer unified SDK — SAPI/Node umbrella covering contracts, runtime, module-loader, db/config/service capabilities, and behavior-pack build.",
  "type": "module",
  "license": "ISC",
  "author": "Shiroha7z",
  "homepage": "https://github.com/DogeLakeDev/ScriptsForMinecraftServer/tree/main/modules/sdk/@sfmc-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DogeLakeDev/ScriptsForMinecraftServer.git",
    "directory": "modules/sdk/@sfmc-sdk"
  },
  "bugs": {
    "url": "https://github.com/DogeLakeDev/ScriptsForMinecraftServer/issues"
  },
  "keywords": [
    "minecraft-bedrock",
    "sapi",
    "sdk",
    "modules",
    "scriptsforminecraftserver"
  ],
  "exports": {
    "./contracts": {
      "types": "./dist/types/contracts/index.d.ts",
      "import": "./dist/esm/contracts/index.js",
      "default": "./dist/esm/contracts/index.js"
    },
    "./logs": {
      "types": "./dist/types/logs/index.d.ts",
      "import": "./dist/esm/logs/index.js",
      "default": "./dist/esm/logs/index.js"
    },
    "./sapi/sdk": {
      "types": "./dist/types/sapi/sdk/index.d.ts",
      "import": "./dist/esm/sapi/sdk/index.js",
      "default": "./dist/esm/sapi/sdk/index.js"
    },
    "./sapi/host": {
      "types": "./dist/types/sapi/host/index.d.ts",
      "import": "./dist/esm/sapi/host/index.js",
      "default": "./dist/esm/sapi/host/index.js"
    },
    "./sapi/runtime": {
      "types": "./dist/types/sapi/runtime/index.d.ts",
      "import": "./dist/esm/sapi/runtime/index.js",
      "default": "./dist/esm/sapi/runtime/index.js"
    },
    "./sapi/db": {
      "types": "./dist/types/sapi/db/index.d.ts",
      "import": "./dist/esm/sapi/db/index.js",
      "default": "./dist/esm/sapi/db/index.js"
    },
    "./sapi/config": {
      "types": "./dist/types/sapi/config/index.d.ts",
      "import": "./dist/esm/sapi/config/index.js",
      "default": "./dist/esm/sapi/config/index.js"
    },
    "./sapi/service": {
      "types": "./dist/types/sapi/service/index.d.ts",
      "import": "./dist/esm/sapi/service/index.js",
      "default": "./dist/esm/sapi/service/index.js"
    },
    "./node/sdk": {
      "types": "./dist/types/node/sdk/index.d.ts",
      "import": "./dist/esm/node/sdk/index.js",
      "default": "./dist/esm/node/sdk/index.js"
    },
    "./node": {
      "types": "./dist/types/node/node/index.d.ts",
      "import": "./dist/esm/node/node/index.js",
      "default": "./dist/esm/node/node/index.js"
    },
    "./node/config": {
      "types": "./dist/types/node/config/index.d.ts",
      "import": "./dist/esm/node/config/index.js",
      "default": "./dist/esm/node/config/index.js"
    },
    "./module-loader": {
      "types": "./dist/types/module-loader/index.d.ts",
      "import": "./dist/esm/module-loader/index.js",
      "default": "./dist/esm/module-loader/index.js"
    },
    "./behavior-pack-build": {
      "types": "./dist/types/behavior-pack-build/index.d.ts",
      "import": "./dist/esm/behavior-pack-build/index.js",
      "default": "./dist/esm/behavior-pack-build/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "build:js": "node build.mjs",
    "build:types": "tsc -p tsconfig.types.json",
    "typecheck": "tsc --noEmit -p tsconfig.types.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build:types && node build.mjs"
  },
  "peerDependencies": {
    "@minecraft/server": ">=2.10.0-beta",
    "@minecraft/server-ui": ">=2.2.0-beta"
  },
  "peerDependenciesMeta": {
    "@minecraft/server": {
      "optional": true
    },
    "@minecraft/server-ui": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
